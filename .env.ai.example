# Must match AI_SERVICE_TOKEN in the main Django .env.
AI_SERVICE_TOKEN=change-me-local-ai-secret

# Local Docker path to Django. Works when main docker-compose.yml is already running.
AI_DJANGO_BASE_URL=http://web:8000

# OpenAI credentials live on the AI side.
OPENAI_API_KEY=
# GPT_TOKEN=

# Optional proxy reused by the OpenAI HTTP client.
TELEGRAM_SOCKS5_PROXY=

# Worker runtime.
AI_WORKER_ID=ai-worker-local-1
AI_WORKER_POLLING_INTERVAL=10
AI_WORKER_LEASE_SECONDS=900
LOG_LEVEL=INFO

# Models.
OPENAI_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_MAX_RETRIES=5
OPENAI_TRANSCRIBE_MAX_SECONDS=1400
OPENAI_TRANSCRIBE_CHUNK_SECONDS=1100
OPENAI_TRANSCRIBE_CHUNK_OVERLAP_SECONDS=2
